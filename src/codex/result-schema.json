{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["reply"],
  "additionalProperties": false,
  "properties": {
    "reply": {
      "type": "string"
    },
    "attachments": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["type", "path"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "const": "file"
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
